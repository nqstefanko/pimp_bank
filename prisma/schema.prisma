generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Question {
  id           Int      @id @default(autoincrement())
  rotation     String
  service      String
  subspecialty String?
  question     String
  answer       String
  voteCount    Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}
